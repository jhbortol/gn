{
    "navigationFallback": {
        "rewrite": "/index.html"
    },
    "responseOverrides": {
        "404": {
            "rewrite": "/index.html"
        }
    },
    "globalHeaders": {
        "Cache-Control": "public, max-age=3600, s-maxage=86400"
    },
    "routes": [
        {
            "route": "/",
            "redirect": "/piracicaba",
            "statusCode": 301
        },
        {
            "route": "/categorias",
            "redirect": "/piracicaba/categorias",
            "statusCode": 301
        },
        {
            "route": "/piracicaba/termos",
            "redirect": "/piracicaba/institucional/termos",
            "statusCode": 301
        },
        {
            "route": "/piracicaba/institucional/sobre-nos",
            "redirect": "/piracicaba/institucional/sobre",
            "statusCode": 301
        },
        {
            "route": "/piracicaba/guia-precos/bolo",
            "redirect": "/piracicaba/guia-precos",
            "statusCode": 301
        },
        {
            "route": "/piracicaba/guia-precos/buffet",
            "redirect": "/piracicaba/guia-precos",
            "statusCode": 301
        },
        {
            "route": "/piracicaba/guia-precos/convites",
            "redirect": "/piracicaba/guia-precos",
            "statusCode": 301
        },
        {
            "route": "/piracicaba/guia-precos/decoracao",
            "redirect": "/piracicaba/guia-precos",
            "statusCode": 301
        },
        {
            "route": "/piracicaba/guia-precos/fotografia",
            "redirect": "/piracicaba/guia-precos",
            "statusCode": 301
        },
        {
            "route": "/piracicaba/guia-precos/vestido",
            "redirect": "/piracicaba/guia-precos",
            "statusCode": 301
        },
        {
            "route": "/index.html",
            "headers": {
                "Cache-Control": "public, max-age=0, s-maxage=0, must-revalidate, no-store",
                "Pragma": "no-cache",
                "Expires": "0"
            }
        },
        {
            "route": "/*.js",
            "headers": {
                "Cache-Control": "public, max-age=31536000, s-maxage=31536000, immutable"
            }
        },
        {
            "route": "/*.css",
            "headers": {
                "Cache-Control": "public, max-age=31536000, s-maxage=31536000, immutable"
            }
        },
        {
            "route": "/sitemap.xml",
            "headers": {
                "Cache-Control": "public, max-age=3600, s-maxage=86400"
            }
        },
        {
            "route": "/main.*.js",
            "headers": {
                "Cache-Control": "public, max-age=31536000, s-maxage=31536000, immutable"
            }
        }
    ]
}